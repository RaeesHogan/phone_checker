generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String
  fullName     String
  role         Role          @default(USER)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  auditLogs    AuditLog[]
  reservations Reservation[]
}

model Reservation {
  id              String            @id @default(cuid())
  customerName    String
  phoneNumber     String
  address         String
  productCode     String?           // Made optional for transition
  totalPrice      Decimal           @default(0)
  notes           String?
  status          Status            @default(ACTIVE)
  reservationDate DateTime          @default(now())
  expirationDate  DateTime
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [createdBy], references: [id])
  items           ReservationItem[]

  @@index([phoneNumber])
  @@index([status])
  @@index([expirationDate])
}

model ReservationItem {
  id            String      @id @default(cuid())
  reservationId String
  productCode   String
  phoneNumber   String      // Added for strict main product locking index
  status        Status      @default(ACTIVE) // Synced from Reservation for partial unique index
  quantity      Int         @default(1)
  isMainProduct Boolean     @default(false)
  createdAt     DateTime    @default(now())
  
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([productCode])
  @@index([reservationId])
  @@index([phoneNumber])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model SystemLog {
  id         String   @id @default(cuid())
  level      String
  source     String
  message    String
  stackTrace String?
  requestId  String?
  createdAt  DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  USER
}

enum Status {
  ACTIVE
  EXPIRED
  CANCELLED
}
